<editors:UserControlBase x:Class="Dyvenix.GenIt.DslPackage.Editors.Model.Controls.ModelRootEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Dyvenix.GenIt.DslPackage.Editors.Model.Controls"
             xmlns:editors="clr-namespace:Dyvenix.GenIt.DslPackage.Editors"
             xmlns:controls="clr-namespace:Dyvenix.GenIt.DslPackage.Editors.Controls"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="900"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"
                                BorderThickness="1,1,1,0" Padding="8,4" Margin="0,0,2,0">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" 
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3D3D3D"/>
                                <Setter TargetName="Border" Property="Margin" Value="0,0,2,-1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource {x:Static vsshell:VsColors.ToolWindowTabGradientBeginKey}}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource {x:Static vsshell:VsColors.ToolWindowTabMouseOverBackgroundBeginKey}}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Small button style for browse button -->
        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="MinWidth" Value="24"/>
        </Style>
        <!-- Color button style -->
        <Style x:Key="ColorButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <!-- DataGrid styles for dark theme -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
            <Setter Property="RowBackground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#4D4D4D"/>
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTabMouseOverBackgroundBeginKey}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="leftColumn" Width="*" MinWidth="300"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="rightColumn" Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - General Settings -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header row: Model + Include Headers (aligned) -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Model" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                <CheckBox Grid.Column="1" x:Name="chkInclHeader" Content="Include Headers" VerticalAlignment="Center"
                          Checked="chkInclHeader_Changed" Unchecked="chkInclHeader_Changed"/>
            </Grid>

            <!-- Templates Folder -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="Templates Folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="txtTemplatesFolder" VerticalAlignment="Center"
                         TextChanged="txtTemplatesFolder_TextChanged"/>
                <Button Grid.Column="1" x:Name="btnBrowseTemplates" Content="..." 
                        Style="{StaticResource SmallButtonStyle}" Margin="4,0,0,0"
                        Click="btnBrowseTemplates_Click" ToolTip="Browse for folder"/>
                </Grid>
            </Grid>

            <!-- Colors row: Background + Line (aligned horizontally) -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" Content="Background Color:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="1" x:Name="btnDiagramBackgroundColor" Style="{StaticResource ColorButtonStyle}"
                        HorizontalAlignment="Left" Margin="0,0,24,0"
                        Click="btnDiagramBackgroundColor_Click" ToolTip="Click to change color"/>

                <Label Grid.Column="2" Content="Line Color:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="3" x:Name="btnAssociationLineColor" Style="{StaticResource ColorButtonStyle}"
                        HorizontalAlignment="Left"
                        Click="btnAssociationLineColor_Click" ToolTip="Click to change color"/>
            </Grid>

            <!-- Usings (fill remaining space like Entity editor Service tab) -->
            <controls:StringListControl Grid.Row="3" x:Name="modelRootUsingsControl"
                                        Title="Usings" DialogTitle="Add Using" DialogLabel="Using:"
                                        ItemsChanged="modelRootUsingsControl_ItemsChanged"/>
        </Grid>

        <!-- GridSplitter -->
        <GridSplitter x:Name="gridSplitter" Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"
                      Margin="8,0" DragCompleted="gridSplitter_DragCompleted"/>

        <!-- Right Panel - Tab Control -->
        <TabControl Grid.Column="2" x:Name="tabControl">
            <!-- DbContext Tab -->
            <TabItem Header="DbContext">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Enabled checkbox at top-right -->
                    <CheckBox Grid.Row="0" Grid.Column="1" x:Name="chkDbContextEnabled" Content="Enabled"
                              HorizontalAlignment="Right" Margin="0,0,0,12"
                              Checked="chkDbContextEnabled_Changed" Unchecked="chkDbContextEnabled_Changed"/>

                    <!-- DbContext Name -->
                    <Label Grid.Row="1" Grid.Column="0" Content="DbContext Name:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtDbContextName" VerticalAlignment="Center" Margin="0,0,0,8"
                             TextChanged="txtDbContextName_TextChanged"/>

                    <!-- Output Folder -->
                    <Label Grid.Row="2" Grid.Column="0" Content="Output Folder:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="txtDbContextOutputFolder" VerticalAlignment="Center"
                                 TextChanged="txtDbContextOutputFolder_TextChanged"/>
                        <Button Grid.Column="1" x:Name="btnBrowseDbContextFolder" Content="..." 
                                Style="{StaticResource SmallButtonStyle}" Margin="4,0,0,0"
                                Click="btnBrowseDbContextFolder_Click" ToolTip="Browse for folder"/>
                    </Grid>

                    <!-- Namespace -->
                    <Label Grid.Row="3" Grid.Column="0" Content="Namespace:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtDbContextNamespace" VerticalAlignment="Center" Margin="0,0,0,8"
                             TextChanged="txtDbContextNamespace_TextChanged"/>

                    <!-- Usings -->
                    <controls:StringListControl Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="dbContextUsingsControl"
                                                Title="Usings" DialogTitle="Add Using" DialogLabel="Using:"
                                                ItemsChanged="dbContextUsingsControl_ItemsChanged"/>
                </Grid>
            </TabItem>

            <!-- Entities Tab -->
            <TabItem Header="Entities">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Enabled checkbox at top-right -->
                    <CheckBox Grid.Row="0" Grid.Column="1" x:Name="chkEntitiesEnabled" Content="Enabled"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              Checked="chkEntitiesEnabled_Changed" Unchecked="chkEntitiesEnabled_Changed"/>

                    <!-- Output Folder -->
                    <Label Grid.Row="1" Grid.Column="0" Content="Output Folder:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="txtEntitiesOutputFolder" VerticalAlignment="Center"
                                 TextChanged="txtEntitiesOutputFolder_TextChanged"/>
                        <Button Grid.Column="1" x:Name="btnBrowseEntitiesFolder" Content="..." 
                                Style="{StaticResource SmallButtonStyle}" Margin="4,0,0,0"
                                Click="btnBrowseEntitiesFolder_Click" ToolTip="Browse for folder"/>
                    </Grid>

                    <!-- Namespace -->
                    <Label Grid.Row="2" Grid.Column="0" Content="Namespace:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtEntitiesNamespace" VerticalAlignment="Center" Margin="0,0,0,8"
                             TextChanged="txtEntitiesNamespace_TextChanged"/>
                </Grid>
            </TabItem>

            <!-- Enums Tab -->
            <TabItem Header="Enums">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Enabled checkbox at top-right -->
                    <CheckBox Grid.Row="0" Grid.Column="1" x:Name="chkEnumsEnabled" Content="Enabled"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              Checked="chkEnumsEnabled_Changed" Unchecked="chkEnumsEnabled_Changed"/>

                    <!-- Output Folder -->
                    <Label Grid.Row="1" Grid.Column="0" Content="Output Folder:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="txtEnumsOutputFolder" VerticalAlignment="Center"
                                 TextChanged="txtEnumsOutputFolder_TextChanged"/>
                        <Button Grid.Column="1" x:Name="btnBrowseEnumsFolder" Content="..." 
                                Style="{StaticResource SmallButtonStyle}" Margin="4,0,0,0"
                                Click="btnBrowseEnumsFolder_Click" ToolTip="Browse for folder"/>
                    </Grid>

                    <!-- Namespace -->
                    <Label Grid.Row="2" Grid.Column="0" Content="Namespace:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtEnumsNamespace" VerticalAlignment="Center" Margin="0,0,0,8"
                             TextChanged="txtEnumsNamespace_TextChanged"/>
                </Grid>
            </TabItem>

            <!-- Permissions Tab -->
            <TabItem Header="Permissions">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header with buttons -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="Permissions" VerticalAlignment="Center" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Button x:Name="btnAddPermission" ToolTip="Add Permission" Click="btnAddPermission_Click" 
                                    Style="{StaticResource SmallButtonStyle}" Padding="4">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <Button x:Name="btnDeletePermission" ToolTip="Delete Permission" Click="btnDeletePermission_Click" 
                                    Style="{StaticResource SmallButtonStyle}" Padding="4" Margin="2,0,0,0">
                                <Path Data="M2,4 L5,4 L5,2 C5,1.45 5.45,1 6,1 L11,1 C11.55,1 12,1.45 12,2 L12,4 L15,4 L15,5 L14,5 L14,15 C14,15.55 13.55,16 13,16 L4,16 C3.45,16 3,15.55 3,15 L3,5 L2,5 L2,4 Z M6,4 L11,4 L11,2.5 L6,2.5 L6,4 Z M4,5 L4,15 L13,15 L13,5 L4,5 Z M5.5,7 L6.5,7 L6.5,13 L5.5,13 L5.5,7 Z M8,7 L9,7 L9,13 L8,13 L8,7 Z M10.5,7 L11.5,7 L11.5,13 L10.5,13 L10.5,7 Z" 
                                      Fill="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}" 
                                      Width="15" Height="15" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                    
                    <!-- Permissions DataGrid -->
                    <DataGrid Grid.Row="1" x:Name="grdPermissions"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CellEditEnding="grdPermissions_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Width="150" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</editors:UserControlBase>
